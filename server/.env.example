FLASK_APP=app
FLASK_ENV=development
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=8000

SECRET_KEY=change-me
JWT_SECRET_KEY=change-me
SECURITY_PASSWORD_SALT=change-me

DB_CONNECTION_STRING=mongodb+srv://USER:PASSWORD@HOST/?retryWrites=true&w=majority

AOAI_ENDPOINT=https://YOUR-AZURE-OPENAI-RESOURCE.openai.azure.com/
AOAI_KEY=your-azure-openai-key
AOAI_API_VERSION=2024-05-01-preview
EMBEDDINGS_DEPLOYMENT_NAME=embeddings
COMPLETIONS_DEPLOYMENT_NAME=completions

BASE_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
RESET_PASSWORD_BASE_URL=http://localhost:3000/reset_password/

TAVILY_API_KEY=your-tavily-key
BING_SUBSCRIPTION_KEY=your-bing-key
BING_SEARCH_URL=https://api.bing.microsoft.com/v7.0/search
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CSE_ID=your-google-cse-id
YOUTUBE_API_KEY=your-youtube-api-key
GPLACES_API_KEY=your-google-places-key

SPEECH_AI_KEY=your-azure-speech-key
SERVICE_REGION=eastus

AZURE_TEXT_ANALYTICS_KEY=your-text-analytics-key
AZURE_TEXT_ANALYTICS_ENDPOINT=https://YOUR-TEXT-ANALYTICS-RESOURCE.cognitiveservices.azure.com/
AZURE_MAPS_KEY=your-azure-maps-key

VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key

MAIL_SERVER=smtp.gmail.com
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
